# Python bytecode and caches
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
.coverage.*
htmlcov/

# Virtual environments
.venv/
.venv-sys/
venv/
env/

# Notebook and OS/IDE artifacts
.ipynb_checkpoints/
.DS_Store
.vscode/
.idea/

# Build/distribution artifacts
build/
dist/
*.egg-info/



# Keep output folder structure in git
!outputs/results/.gitkeep
!outputs/plots/.gitkeep
!outputs/logs/.gitkeep

# Optional local environment files
.env
.env.*

# Hugging Face / model caches (local machine)
.cache/
huggingface/
